using "emScriptCore.dll"

//-----------------------------------------------------------------------------
//
//-----------------------------------------------------------------------------
// SET UP AND GLBOAL VARIABLE(S)
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------

//-----------------------------------------------------------------------------
// LOGICAL CONTROL CONSTANT(S)
//-----------------------------------------------------------------------------

int	true				= 1
int	false				= 0

//-----------------------------------------------------------------------------
// SCRIPT INFORMATION
//-----------------------------------------------------------------------------

String	strScriptName			= GetScriptName()
String	strScriptVersion		= "1.3.3"
String	strEngineVersion		= GetemScriptVersion()
int		iCRC					= CalcFileCRC(strScriptName)
String	strESN					= GetESN()

//-----------------------------------------------------------------------------
// SCRIPT REGISTRY SETTINGS
//-----------------------------------------------------------------------------

String	strEMScriptKey			= "HKEY_CURRENT_USER\\Software\\Symbol\\emScript"
String	strNextSnapshotKey		= "NextSnapshot"
String	strCmdFileCRCKey		= "Command File CRC"

//-----------------------------------------------------------------------------
// SCRIPT OUTPUT|INSTALLATION CONFIGURATION
//-----------------------------------------------------------------------------

String	strTmpDir			= "\\Temp\\"
String	strAppDir			= "\\Application\\"
String	strEMScriptDir			= strAppDir + "eMScript\\"
String	strStorageDir			= strEMScriptDir

String	strLogFile			= strStorageDir + "Resource" + strESN + ".csv"
String	strLogFileBackuPExt		= ".bk.csv"

String	strRMFile			= strStorageDir + "RetailMsg.txt"
String	strRMFileBackupExt		= ".bk.txt"

String	strParameterSep			= ","

//-----------------------------------------------------------------------------
// BASIC SCRIPT CONFIGURATION - ENABLE SECTIONS/FEATURES
//-----------------------------------------------------------------------------

int	iLogInterval			= 60000		// RESOURCE LOG ENTRY INTERVAL (60 SECONDS)
int	iLogFileSizeMax			= (512*1024)	// MAXIMUM LOG FILE SIZE IN BYTES

int	iLogWLANInformation		= true		// LOG WLAN (802.11) INFORMATION (IF AVAILABLE)
int	iLogWANInformation		= true		// LOG WAN INFORMATION (IF AVAILABLE)
int	iLogWANRSSI			= false		// SEND AT COMMANDS FOR RSSI (ONLY ENABLE ON CINTERION HC25 AND MC75 MODEMS)
int	iLogGatewayPingRTT		= false		// PING DEFAULT GATEWAY AND LOG ROUND TRIP TIME
int	iLogGPSInformation		= false		// LOG GPS INFORMATION (IF AVAILABLE)
int iRTLogEnable 				= true		// LOG RETAIL MESSAGES TO FILE IF THIS IS TRUE
int iIsRTLogSupported			= false		// CHECK IF RTLOG MESSAGES ARE SUPPORTED ON DEVICE - THIS WILL BE ENABLED PER DEVICE BELOW

//-----------------------------------------------------------------------------
// SNAPSHOT CONFIGURATION
//-----------------------------------------------------------------------------

int	iSnapshotEnable			= true		// ENABLE SySTEM SNAPSHOTS
int	iSnapshotInterval		= 1800000	// 30 MINUTES
int	iSnapshotMax			= 96		// 48 HOURS WORTH
int	iSnapshotNext			= GetRegistryDWORD( strEMScriptKey, strNextSnapshotKey, 1)

//-----------------------------------------------------------------------------
// FTP PUSH|PULL CONFIGURATION
//-----------------------------------------------------------------------------

int	iDoPush				= false			// ENABLE FTP UPLOAD FUNCTIONALITY
int	iDoPushOnStart			= false		// ENABLE FTP UPLOAD ON STARTUP
int	iDoPull				= false			// ENABLE FTP COMMAND FILE DOWNLOAD FUNCTIONALITY

String	strPushPullClient		= strEMScriptDir + "PushPullClient.exe"
String	strEmAgent			= strEMScriptDir + "emAgent.exe"
String	strPushDir			= strAppDir + "PushPullClient\\Push\\"
String	strPullDir			= strAppDir + "PushPullClient\\Pull\\"
String	strCommandScript		= strPulldir + "Command.mot"
String	strPullHBEvent			= "HBSymScriptGetCommandEvent"	// PULL HEARTBEAT EVENT

String	strPushRegKey			= "HKEY_LOCAL_MACHINE\\Software\\Symbol\\PushPullClient"

String	strFTPHost			= "ftp.somewhere.com"
String	strFTPUser			= "ftpuser"
String	strFTPPassword			= "password"
String	strFTPRemRoot			= "/eMscript/Push"
String	strFTPRemPullDir		= "/eMscript/Pull"
String	strFTPRemPullFile		= "Command.mot"
String	strWakeupTime			= "05:00:00"

int iFTPRetryDelay			= 5000
int iFTPPushInterval			= 600000
int iFTPPullInterval			= 800000
int iFTPDoLog				= 0
int iFTPDoWakeup			= 1

int iPullDoneEventData			= 900		// EVENT DATA WHEN PULL COMPLETE
int iCmdFileCRC				= GetRegistryDWORD( strEMScriptKey, strCmdFileCRCKey, 0)

//-----------------------------------------------------------------------------
// RETAIL MSG CONFIGURATION
//-----------------------------------------------------------------------------
int iRMIOCTLs				= 0	// DEFAULT TO MPA1.0 IOCTLS, 1 FOR MPA1.5, 2 FOR MPA 2.0
int iRMLogMaxFileSize			= ( 512 * 1024 )	// DEFAULT IS 512 KB (1 MB WITH BACKUP). FOR 10 MB (20 MB WITH BACKUP), CHANGE THIS VALUE TO 10485760
string strRTLogPath			= "\\Application\\emScript"	// PATH WHERE RETAILMSG LOGS WILL BE EXPORTED
int iRTLogInterval			= 60				// INTERVAL TO WRITE RETILMSG BUFFER FOR BSP'S WHICH DON'T SUPPORT LAZY-EXPORT
//-----------------------------------------------------------------------------
// STATUS CODE DEFINITIONS
//-----------------------------------------------------------------------------

int iInformationalMessage		= 100			
int iPowerEventMessage			= 200
int iCommandMessage			= 300
int iWANEvent				= 400
int iMemMapMessage			= 500
	
//-----------------------------------------------------------------------------
// SYSTEM GLOBAL|CACHED VARIABLE(S)
//-----------------------------------------------------------------------------

int iCode				= 0

int iBootCount				= GetBootCount()
String	strBattSerial			= GetSmartBatteryStatus( 0 )
String	strBattCycles			= GetSmartBatteryStatus( 2 )
String	strBattCap			= GetSmartBatteryStatus( 3 )
//String	strESN				= GetESN()

int iLogMutex				= CreateMutexEx()
int iLogMessageCode			= iInformationalMessage
String	strLogMessageText		= "Heartbeat"

string	strOEMInfo			= GetOEMInfo()
string	strOEMVersion			= GetOEMVersion()
int iIsWinMobile			= 1

//-----------------------------------------------------------------------------
// WAN GLOBAL|CACHED VARIABLE(S)
//-----------------------------------------------------------------------------

String	strWANCallNo			= ""
String	strWANCallDuration		= ""
String	strWANCallStart			= ""
String	strWANCellInfo			= ""

int iWANTemp				= 0
int iWANIncomingCallTimeTotal		= 0
int iWANOutgoingCallTimeTotal		= 0

//-----------------------------------------------------------------------------
// GPS GLOBAL|CACHED VARIABLE(S)
//-----------------------------------------------------------------------------

float	fGPSInvalidLatitude		= -99.0
float	fGPSInvalidLongitude		= -190.0
float	fGPSCachedLatitude		= fGPSInvalidLatitude
float	fGPSCachedLongitude		= fGPSInvalidLongitude

//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
// MAIN BODY
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------

//-----------------------------------------------------------------------------
// TERMINAL DETECTION - AUTOMATIC CONFIGURATION
//-----------------------------------------------------------------------------

// DETECT WINDOWS MOBILE OR WINDOWS CE
if ( GetPlatformType() == "PocketPC" )
{
	iIsWinMobile = 1
}
else
{
	iIsWinMobile = 0
}

// NOTE:	This method will not properly detect terminals with older OS's that
//			display SYMBOL.  This is okay for now as RMLogger doesn't work on
//			those OS's.  If we need to add an automatic configuration parameter
//			for these OS's we must change the logic to detect both SYMBOL and
//			MOTOROLA.
// MC70 Specific Config
if ( strOEMInfo == "MOTOROLA MC70" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
	}
}

// MC3100 Specific Config
else if ( strOEMInfo == "MOTOROLA MC3100S" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA MC3100S-MOTOROLA WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC3190R Specific Config
else if ( strOEMInfo == "MOTOROLA MC3100R" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA MC3100R-MOTOROLA WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC3190 Specific Config
else if ( strOEMInfo == "MOTOROLA MC3100G" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLS = 2
	}
	else
	{
// "MOTOROLA MC3100G-MOTOROLA WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC65 Specific Config
else if ( strOEMInfo == "Motorola MC65" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// ES400 Specific Config
else if( strOEMInfo == "Motorola ES400" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC75 Specific Config
else if ( strOEMInfo == "MOTOROLA MC75" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 1
	}
}

// MC75A Specific Config
else if ( strOEMInfo == "MOTOROLA MC75A" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC55 Specific Config
else if ( strOEMInfo == "MOTOROLA MC55" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 1
	}
}

// MC55A Specific Config
else if ( strOEMInfo == "MOTOROLA MC55A" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC55N Specific Config
else if ( strOEMInfo == "MOTOROLA MC55N" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC9090 Specific Config
else if (	(strOEMInfo == "MOTOROLA MC9090G") || 
			(strOEMInfo == "MOTOROLA MC9090K") ||
			(strOEMInfo == "MOTOROLA MC9090S") )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
	}
	else
	{
//	"MOTOROLA 9090 WinCE"
		iIsRTLogSupported = true
	}
}

// MC95 Specific Config
else if ( strOEMInfo == "MOTOROLA MC95" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC9190 Specific Config
else if ( strOEMInfo == "MOTOROLA MC9190G" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA MC9190G-MOTOROLA WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC2180 Specific Config
else if ( strOEMInfo == "MOTOROLA MC2180" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA MC2180-MOTOROLA WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC45 Specific Config
else if ( strOEMInfo == "Motorola MC45" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// SB1N Specific Config
else if ( strOEMInfo == "MOTOROLA SB1N" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA SB1N WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// SB1B Specific Config
else if ( strOEMInfo == "MOTOROLA SB1B" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
	else
	{
// "MOTOROLA SB1B WinCE"
		iIsRTLogSupported = true
		iRMIOCTLs = 2
	}
}

// MC67 Specific Config
else if ( strOEMInfo == "Motorola MC67" )
{
	if ( iIsWinMobile )
	{
		iIsRTLogSupported = true
