# ============================================
# SAC v1.0 - Variables de Entorno
# Sistema de Automatización de Consultas
# CEDIS Cancún 427 - Tiendas Chedraui
# ============================================
#
# ✅ ESTE ARCHIVO ESTÁ PRE-CONFIGURADO
# 
# SOLO DEBES COMPLETAR:
# 1. DB_USER (tu usuario de DB2)
# 2. DB_PASSWORD (tu contraseña de DB2)  
# 3. EMAIL_USER (tu correo corporativo)
# 4. EMAIL_PASSWORD (tu contraseña de correo)
#
# INSTRUCCIONES:
# 1. Copia este archivo a la raíz como .env
#    Comando: copy config\.env.example .env
# 2. Edita el archivo .env con tus credenciales
#    Comando: notepad .env
# 3. Guarda y cierra
# 4. NUNCA subas el archivo .env a Git
#
# ============================================

# ============================================
# 🔒 CREDENCIALES - COMPLETAR OBLIGATORIO
# ============================================

# Base de Datos DB2
DB_USER=                                    # ← TU USUARIO DB2 AQUÍ
DB_PASSWORD=                                # ← TU CONTRASEÑA DB2 AQUÍ

# Email Corporativo
EMAIL_USER=                                 # ← TU CORREO @chedraui.com.mx AQUÍ
EMAIL_PASSWORD=                             # ← TU CONTRASEÑA DE CORREO AQUÍ

# ============================================
# ✅ BASE DE DATOS DB2 - MANHATTAN WMS
# ============================================
# Configuración completa del servidor DB2
# Puerto estándar: 50000
# Timeout de conexión: 30 segundos

DB_HOST=WM260BASD
DB_PORT=50000
DB_DATABASE=WM260BASD
DB_SCHEMA=WMWHSE1
DB_DRIVER={IBM DB2 ODBC DRIVER}
DB_TIMEOUT=30
DB_POOL_SIZE=5

# ============================================
# ✅ CONFIGURACIÓN DE CEDIS CANCÚN
# ============================================
# Información del Centro de Distribución
# Código oficial: 427
# Almacén Manhattan: C22
# Región: Sureste

CEDIS_CODE=427
CEDIS_NAME=CEDIS Cancún
CEDIS_REGION=Sureste
CEDIS_ALMACEN=C22
CEDIS_WAREHOUSE=WM260BASD
CEDIS_LOCATION=Cancún, Quintana Roo

# ============================================
# ✅ CONFIGURACIÓN DE EMAIL - OFFICE 365
# ============================================
# Servidor SMTP: Office 365 corporativo
# Puerto TLS: 587 (estándar seguro)
# Autenticación: OAuth2 / Credenciales

EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_PROTOCOL=TLS
EMAIL_FROM=sac.cedis427@chedraui.com.mx
EMAIL_FROM_NAME=Sistema SAC - CEDIS Cancún 427

# Destinatarios por prioridad
# CRÍTICO: Planning y Jefatura
EMAIL_TO_CRITICAL=planning@chedraui.com.mx,jefatura.cedis427@chedraui.com.mx

# NORMAL: Operaciones y Sistemas
EMAIL_TO_NORMAL=operaciones.cedis427@chedraui.com.mx,sistemas.cedis427@chedraui.com.mx

# Copia (CC)
EMAIL_CC=siterfvh@chedraui.com.mx

# Configuración adicional
EMAIL_SSL=true
EMAIL_ENABLE=true
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=5

# ============================================
# ✅ CONFIGURACIÓN DE RUTAS Y DIRECTORIOS
# ============================================
# Estructura de carpetas del proyecto
# Automáticamente se crean si no existen

OUTPUT_DIR=./output
LOGS_DIR=./output/logs
RESULTADOS_DIR=./output/resultados
REPORTES_DIR=./output/reportes
TEMP_DIR=./output/temp
QUERIES_DIR=./queries

# ============================================
# ✅ CONFIGURACIÓN DE LOGGING
# ============================================
# Nivel de detalle de logs
# DEBUG: Máximo detalle (desarrollo)
# INFO: Información general (producción)
# WARNING: Solo advertencias
# ERROR: Solo errores

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ============================================
# ✅ CONFIGURACIÓN DEL SISTEMA
# ============================================
# Parámetros generales de operación

SYSTEM_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
ENABLE_ALERTS=true
ENABLE_EMAIL=true
ENABLE_SCHEDULER=true

# Zona horaria (CRÍTICO para programación)
TIMEZONE=America/Cancun

# ============================================
# ✅ CONFIGURACIÓN DE REPORTES EXCEL
# ============================================
# Formato y estilo de reportes

EXCEL_ENGINE=openpyxl
EXCEL_MAX_ROWS=1000000
EXCEL_AUTOFIT_COLUMNS=true
EXCEL_FREEZE_PANES=true
EXCEL_ADD_FILTERS=true
EXCEL_ALTERNATING_ROWS=true

# Colores corporativos Chedraui (HEX)
COLOR_HEADER=E31837
COLOR_SUBHEADER=F8CBAD
COLOR_OK=92D050
COLOR_WARNING=FFC000
COLOR_ERROR=FF0000
COLOR_INFO=B4C7E7

# ============================================
# ✅ CONFIGURACIÓN DE QUERIES SQL
# ============================================
# Timeouts y límites de ejecución

QUERY_TIMEOUT=300
QUERY_MAX_RETRIES=3
QUERY_FETCH_SIZE=1000
QUERY_ENABLE_CACHE=false

# ============================================
# ✅ CONFIGURACIÓN DE AUTOMATIZACIÓN
# ============================================
# Horarios de ejecución automática
# Formato: HH:MM (24 horas)

SCHEDULE_PLANNING_AVANCE=09:00
SCHEDULE_PLANNING_FINAL=17:00
SCHEDULE_PROGRAMA_RECIBO=18:00
SCHEDULE_VALIDACION_NOCTURNA=22:00

# Frecuencia de monitoreo de email (segundos)
EMAIL_CHECK_INTERVAL=60

# ============================================
# ✅ CONFIGURACIÓN DE VALIDACIONES
# ============================================
# Tipos de órdenes de compra a validar

# Patrones de OC Chedraui (Regex)
OC_PATTERN_1=750384\d{6}
OC_PATTERN_2=811117\d{6}
OC_PATTERN_3=40[0-9]{11}

# Patrones de LPN (Regex)
LPN_PATTERN=LPN[0-9]{7,10}

# Patrones de ASN (Regex)
ASN_PATTERN=ASN[0-9]{8,12}

# ============================================
# ✅ CONFIGURACIÓN DE SEGURIDAD
# ============================================
# Parámetros de seguridad y encriptación

SECURITY_ENCRYPT_PASSWORDS=true
SECURITY_MIN_PASSWORD_LENGTH=8
SECURITY_SESSION_TIMEOUT=3600
SECURITY_MAX_LOGIN_ATTEMPTS=3

# ============================================
# ✅ CONFIGURACIÓN DE PERFORMANCE
# ============================================
# Optimización y rendimiento

CACHE_ENABLED=false
CACHE_TTL=3600
MAX_WORKERS=4
ASYNC_ENABLED=true
BATCH_SIZE=100

# ============================================
# ✅ CONFIGURACIÓN DE NOTIFICACIONES
# ============================================
# Alertas y notificaciones automáticas

ALERT_CRITICAL_ENABLED=true
ALERT_CRITICAL_EMAIL=true
ALERT_CRITICAL_SMS=false
ALERT_WARNING_ENABLED=true
ALERT_INFO_ENABLED=false

# ============================================
# ✅ CONFIGURACIÓN DE INTEGRACIÓN
# ============================================
# Servicios externos y APIs

# Service Now (opcional)
SERVICENOW_URL=https://chedrauisn.service-now.com
SERVICENOW_ENABLED=false

# SAP (opcional)
SAP_ENABLED=false

# Manhattan WMS Web Services (opcional)
WMS_API_ENABLED=false

# ============================================
# ✅ CONFIGURACIÓN DE DESARROLLO
# ============================================
# Solo para ambiente de desarrollo

DEV_MODE=false
DEV_MOCK_DB=false
DEV_MOCK_EMAIL=false
DEV_VERBOSE=false

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 📌 CREDENCIALES OBLIGATORIAS:
#    - DB_USER
#    - DB_PASSWORD
#    - EMAIL_USER
#    - EMAIL_PASSWORD
#
# 📌 SERVIDOR DB2:
#    - Host: WM260BASD (servidor corporativo)
#    - Puerto: 50000 (estándar DB2)
#    - Database: WM260BASD
#    - Schema: WMWHSE1 (Manhattan WMS)
#
# 📌 EMAIL OFFICE 365:
#    - SMTP: smtp.office365.com
#    - Puerto: 587 (TLS)
#    - Autenticación: requerida
#
# 📌 ZONA HORARIA:
#    - America/Cancun (UTC-5)
#    - Crítico para programación correcta
#
# 📌 SEGURIDAD:
#    - NUNCA subir .env a Git
#    - NUNCA compartir credenciales
#    - Rotar contraseñas periódicamente
#
# 📌 SOPORTE:
#    - Sistemas CEDIS 427
#    - Ext: 4336
#    - Email: siterfvh@chedraui.com.mx
#
# ============================================
# Versión del archivo: 1.0
